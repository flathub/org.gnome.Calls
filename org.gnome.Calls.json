        {
            "name": "calls",
            "builddir": true,
            "buildsystem": "meson",
            "config-opts": [
                "-Dmanpages=false",
                "-Dsystemd_user_unit_dir=/app/lib/systemd/user"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/GNOME/calls.git",
                    "tag": "v50.0",
                    "commit": "271ab5a5acccbc6de44995414ab2093c1f6688ec",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^v([\\d.]+)$",
